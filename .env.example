# usage-monitor 配置模板
# 说明：
# 1. 本文件给本地命令、docker compose、deploy 脚本共用。
# 2. 建议先复制为 .env，再按自己的环境改值。
# 3. 代码会优先读取 .env；如果进程环境变量里也设置了同名项，则环境变量优先。
# 4. docker compose 会自动读取当前目录下的 .env 做变量替换。

# token JSON 目录。
# 本地运行时建议保持为 ../tokens；docker compose 内会覆盖为 /app/tokens。
USAGE_MONITOR_TOKENS_DIR=../tokens

# SQLite 数据库文件路径。
# 本地运行时建议保持为 ./data/usage-monitor.sqlite3；docker compose 内会覆盖为容器内路径。
USAGE_MONITOR_DB_PATH=./data/usage-monitor.sqlite3

# 连续两轮最终都是 401 时，剪切 JSON 的目标目录。
# 本地运行时建议保持为 ./data/authInvalid；docker compose 内会覆盖为 /app/authInvalid。
USAGE_MONITOR_AUTH_INVALID_DIR=./data/authInvalid

# 页面访问前缀。
# 本地直接运行时保持为空；如果挂到 nginx 子路径，例如 /usage-monitor，则填该值。
USAGE_MONITOR_URL_PREFIX=

# docker compose 宿主机上的 tokens 挂载路径。
# 本地默认指向仓库根目录 tokens；远端部署时改成实际宿主机目录。
USAGE_MONITOR_TOKENS_HOST_PATH=../tokens

# docker compose 宿主机上的数据目录。
# 本地默认写到 usage-monitor/data；远端部署时也建议保留为项目目录下的 ./data。
USAGE_MONITOR_DATA_HOST_PATH=./data

# docker compose 宿主机上的 authInvalid 挂载路径。
# 默认写到仓库目录下的 ./authInvalid；正式环境建议改成实例自己的独立目录。
USAGE_MONITOR_AUTH_INVALID_HOST_PATH=./authInvalid

# 同一轮内，两个账号之间的查询间隔，单位秒。
# 支持小数，最小为 0。
USAGE_MONITOR_PER_ACCOUNT_INTERVAL_SECONDS=3

# 整轮查询完成后的等待时间，单位秒。
# 支持小数，最小为 1。
USAGE_MONITOR_ROUND_INTERVAL_SECONDS=21600

# sleeping 阶段检查手动触发请求的轮询间隔，单位秒。
# 支持小数，最小为 0.2；默认 2 秒已经足够轻量。
USAGE_MONITOR_MANUAL_TRIGGER_POLL_SECONDS=2

# 是否启用 CPA 只读实时状态同步。
# 启用后 collector 只会 GET /v0/management/auth-files，不会修改 CPA 数据。
USAGE_MONITOR_CPA_STATUS_ENABLED=false

# CPA auth-files 只读接口地址。Docker 部署中 collector 使用 host 网络，默认可直接访问 127.0.0.1。
USAGE_MONITOR_CPA_STATUS_URL=http://127.0.0.1:8317/v0/management/auth-files

# CPA management key。正式值只写入 .env，禁止提交到 git。
USAGE_MONITOR_CPA_MANAGEMENT_KEY=

# CPA 只读状态同步间隔，单位秒；最小为 5。
USAGE_MONITOR_CPA_STATUS_SYNC_SECONDS=30

# CPA 只读接口请求超时，单位秒；最小为 1。
USAGE_MONITOR_CPA_STATUS_TIMEOUT_SECONDS=5

# CPA 状态 freshness 窗口，单位秒；过期后页面自动退回 6 小时官方扫描结果。
USAGE_MONITOR_CPA_STATUS_STALE_SECONDS=120

# Web 端 SSE 检查数据库修订号的间隔，单位秒。
# 支持小数，最小为 0.1；默认 0.5 秒可以兼顾实时性与数据库开销。
USAGE_MONITOR_SSE_POLL_SECONDS=0.5

# Web 端 SSE 空闲保活间隔，单位秒。
# 默认 15 秒；用于在代理链路中保持长连接活跃。
USAGE_MONITOR_SSE_PING_SECONDS=15

# Web 端开启 gzip 压缩的最小响应体大小，单位字节。
# 默认 1024；首页和 dashboard JSON 超过该阈值时会自动压缩。
USAGE_MONITOR_WEB_GZIP_MIN_BYTES=1024

# 单次 HTTP 请求超时时间，单位秒。
# 最小为 1。
USAGE_MONITOR_REQUEST_TIMEOUT_SECONDS=30

# 本地 Web 监听地址。
# 本地开发建议保持 127.0.0.1；docker compose 内会覆盖为 0.0.0.0。
USAGE_MONITOR_WEB_HOST=127.0.0.1

# Web 监听端口。
# 本地运行和 docker compose 的端口映射都会使用这个值。
USAGE_MONITOR_WEB_PORT=8765

# 日志级别。
# 可选：DEBUG、INFO、WARNING、ERROR。
USAGE_MONITOR_LOG_LEVEL=INFO

# 可选 HTTP 代理。
# 留空表示不走代理。
HTTP_PROXY=

# 可选 HTTPS 代理。
# 留空表示不走代理。
HTTPS_PROXY=

# 可选 NO_PROXY。
NO_PROXY=127.0.0.1,localhost,::1

# deploy.sh 使用的 SSH 目标。
# 示例：your-server
USAGE_MONITOR_DEPLOY_SSH_TARGET=

# deploy.sh 使用的远端部署目录。
# 示例：/srv/usage-monitor
USAGE_MONITOR_DEPLOY_REMOTE_DIR=

# deploy.sh 安装 Nginx Basic Auth 文件的目标路径。
USAGE_MONITOR_DEPLOY_NGINX_HTPASSWD_PATH=/etc/nginx/usage-monitor.htpasswd

# deploy.sh 健康检查重试次数。
USAGE_MONITOR_DEPLOY_HEALTHCHECK_RETRIES=15

# deploy.sh 两次健康检查之间的等待秒数。
USAGE_MONITOR_DEPLOY_HEALTHCHECK_INTERVAL_SECONDS=2
